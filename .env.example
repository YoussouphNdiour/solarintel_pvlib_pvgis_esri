# SolarIntel v2 — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# cp .env.example .env

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-64-char-hex-string-generated-by-secrets-module

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Development (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+asyncpg://solarintel:solarintel_dev_password@localhost:5432/solarintel

# ── Cache (Redis) ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Anthropic (Claude API) ────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/keys
# Model used: claude-opus-4-6
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── ArcGIS ────────────────────────────────────────────────────────────────────
# Get from: https://developers.arcgis.com/
# Used for: location picker map component (SIM-001)
ARCGIS_API_KEY=your-arcgis-api-key-here

# ── PVGIS (no key required — public API) ──────────────────────────────────────
PVGIS_BASE_URL=https://re.jrc.ec.europa.eu/api/v5_2

# ── Senelec Tariff ────────────────────────────────────────────────────────────
# Residential tariff in CFA Francs per kWh (update with current Senelec rates)
SENELEC_TARIFF_KWH_XOF=121.0

# ── PDF Generation ────────────────────────────────────────────────────────────
PDF_STORAGE_PATH=/tmp/solarintel/reports
PDF_GENERATION_TIMEOUT_SECONDS=60

# ── CORS (comma-separated origins) ───────────────────────────────────────────
# In production, set to your deployed frontend URL
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Frontend (Vite env vars — must be prefixed with VITE_) ───────────────────
VITE_API_BASE_URL=http://localhost:8000
VITE_ARCGIS_API_KEY=your-arcgis-api-key-here
