# SolarIntel v2 — Environment Variables Reference
# Copy this file to .env and fill in real values. Never commit .env to VCS.
#
# Required fields are marked (REQUIRED). All others have safe defaults.

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="SolarIntel v2"
APP_VERSION="2.0.0"
ENVIRONMENT=development          # development | staging | production
DEBUG=false

# ── Security (REQUIRED) ───────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=change_me_use_a_64_char_random_hex_string_here
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for browser clients
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
# asyncpg driver is enforced automatically; you may use postgresql:// or
# postgresql+asyncpg:// — both are accepted.
DATABASE_URL=postgresql+asyncpg://solarintel:password@localhost:5432/solarintel_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis (REQUIRED) ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Anthropic / Claude (REQUIRED) ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── ArcGIS Maps SDK (REQUIRED) ───────────────────────────────────────────────
ARCGIS_API_KEY=your_arcgis_api_key_here

# ── PVGIS Solar Radiation API ─────────────────────────────────────────────────
PVGIS_BASE_URL=https://re.jrc.ec.europa.eu/api/v5_2
PVGIS_CACHE_TTL_DAYS=30

# ── PDF Report Generation ─────────────────────────────────────────────────────
PDF_STORAGE_PATH=/tmp/solarintel/reports
PDF_GENERATION_TIMEOUT_SECONDS=60

# ── Senelec Tariff ────────────────────────────────────────────────────────────
# Base residential tariff rate in CFA Francs per kWh (Senelec 2024 rate)
SENELEC_TARIFF_KWH_XOF=121.0

# ── OAuth2 Google ─────────────────────────────────────────────────────────────
# Obtain from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── WhatsApp Business API ─────────────────────────────────────────────────────
# Obtain from: https://developers.facebook.com/apps/
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# ── Monitoring & Alerting ─────────────────────────────────────────────────────
# Sentry: https://sentry.io — error tracking and performance monitoring
SENTRY_DSN=

# Grafana: optional push gateway for custom metrics
GRAFANA_API_KEY=

# ── Ollama Fallback LLM ───────────────────────────────────────────────────────
# Used as Claude fallback when Anthropic API is unavailable
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
